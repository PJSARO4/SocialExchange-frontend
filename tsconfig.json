{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "_deprecated_routes",
    "_comms_staging",
    "app_backup_before_comms",
    "lib/audio 2",
    "lib/market 2",
    "lib/network 2",
    "lib/logging 2",
    "components/audio/AudioControl 2.tsx",
    "components/audio/MoodBackground 2.tsx",
    ".next/types/*.d 2.ts",
    ".next/types/validator 2.ts"
  ]
}
